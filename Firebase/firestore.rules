rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPlatformAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'claudiofranciscojunior2006@gmail.com';
    }

    function hasExpectedRequesterRole() {
      return (isPlatformAdmin() && request.resource.data.role == 'ADMIN')
        || (!isPlatformAdmin() && request.resource.data.role == 'USER');
    }

    function hasOnlyAllowedKeys(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function hasValidOptionalUserId() {
      return !request.resource.data.keys().hasAny(['userId'])
        || request.resource.data.userId == null
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    function isMedicationOwner() {
      return isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    function hasValidMedicationUpdatePayload() {
      return hasOnlyAllowedKeys(['nome', 'categoria', 'descricao', 'dose_diaria_comprimidos', 'stock', 'requires_prescription', 'active', 'createdBy', 'updatedBy', 'createdAt', 'updatedAt'])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function hasValidInventoryPayload() {
      return hasOnlyAllowedKeys(['pharmacyId', 'medicineId', 'externalSku', 'ean', 'commercialName', 'activeIngredient', 'concentration', 'pharmaceuticalForm', 'availabilityStatus', 'quantityInternal', 'quantityPublic', 'price', 'officialProductUrl', 'source', 'integrationProvider', 'lastSyncAt', 'updatedAt'])
        && request.resource.data.pharmacyId is string
        && request.resource.data.availabilityStatus in ['available', 'low_stock', 'unavailable', 'unknown']
        && request.resource.data.quantityPublic in ['available', 'low_stock', 'unavailable', 'unknown'];
    }

    function hasValidIntegrationLogPayload() {
      return hasOnlyAllowedKeys(['partnerId', 'pharmacyId', 'eventType', 'level', 'message', 'source', 'createdAt'])
        && request.resource.data.pharmacyId is string
        && request.resource.data.level in ['debug', 'info', 'warn', 'error'];
    }

    function hasValidWebhookEventPayload() {
      return hasOnlyAllowedKeys(['eventId', 'partnerId', 'pharmacyId', 'eventType', 'status', 'payloadHash', 'receivedAt'])
        && request.resource.data.eventId is string
        && request.resource.data.pharmacyId is string
        && request.resource.data.status in ['received', 'processed', 'duplicate_ignored', 'failed'];
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && hasExpectedRequesterRole();

      allow read: if isOwner(uid) || isPlatformAdmin();

      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && hasExpectedRequesterRole();

      allow delete: if false;
    }


    match /farmacias/{documentId} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    match /medications/{documentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && hasOnlyAllowedKeys(['nome', 'categoria', 'descricao', 'dose_diaria_comprimidos', 'stock', 'requires_prescription', 'active', 'createdBy', 'updatedBy', 'createdAt', 'updatedAt'])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.active == true;
      allow update: if isPlatformAdmin()
        || (isMedicationOwner() && hasValidMedicationUpdatePayload());
      allow delete: if isPlatformAdmin() || isMedicationOwner();
    }

    match /institutions/{documentId} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    match /inventory/{documentId} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    match /pharmacy_inventory/{documentId} {
      allow read: if true;
      allow create: if isPlatformAdmin() && hasValidInventoryPayload();
      allow update: if isPlatformAdmin() && hasValidInventoryPayload();
      allow delete: if isPlatformAdmin();
    }

    match /integration_logs/{documentId} {
      allow create: if isPlatformAdmin() && hasValidIntegrationLogPayload();
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /webhook_events/{documentId} {
      allow create: if isPlatformAdmin() && hasValidWebhookEventPayload();
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }


    match /platform_settings/{documentId} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    match /contact_forms/{documentId} {
      allow create: if hasOnlyAllowedKeys(['name', 'email', 'phone', 'message', 'userId', 'createdAt', 'status'])
        && request.resource.data.status == 'OPEN';
      allow read, update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /feedbacks/{documentId} {
      allow create: if hasOnlyAllowedKeys(['message', 'category', 'userId', 'createdAt', 'status'])
        && request.resource.data.status == 'OPEN';
      allow read, update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /pharmacy_interest_forms/{documentId} {
      allow create: if hasOnlyAllowedKeys(['pharmacyName', 'responsibleName', 'email', 'phone', 'city', 'state', 'message', 'userId', 'createdAt', 'status'])
        && request.resource.data.status == 'OPEN';
      allow read, update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /medicine_search_requests/{documentId} {
      allow create: if hasOnlyAllowedKeys(['medicineName', 'normalizedMedicineName', 'city', 'state', 'message', 'userId', 'createdAt', 'status'])
        && request.resource.data.status == 'OPEN';
      allow read, update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /medicine_alerts/{documentId} {
      allow create: if isSignedIn()
        && request.resource.data.status == 'ACTIVE'
        && request.resource.data.userId == request.auth.uid;
      allow read: if isPlatformAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isPlatformAdmin();
    }

    match /delivery_simulations/{documentId} {
      allow create: if true;
      allow read: if isPlatformAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /search_logs/{documentId} {
      allow create: if hasOnlyAllowedKeys(['eventType', 'hasTerm', 'termLength', 'resultCount', 'createdAt'])
        && request.resource.data.eventType == 'MEDICINE_SEARCH';
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /click_logs/{documentId} {
      allow create: if hasOnlyAllowedKeys(['pharmacyId', 'actionType', 'userId', 'createdAt'])
        && hasValidOptionalUserId()
        && request.resource.data.actionType in ['VIEW', 'WHATSAPP_CLICK', 'PHONE_CLICK', 'ADDRESS_CLICK'];
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /form_submit_logs/{documentId} {
      allow create: if hasOnlyAllowedKeys(['formType', 'userId', 'createdAt'])
        && hasValidOptionalUserId();
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /auth_logs/{documentId} {
      allow create: if isSignedIn()
        && hasOnlyAllowedKeys(['method', 'eventType', 'userId', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.method in ['email', 'google']
        && request.resource.data.eventType in ['LOGIN', 'SIGN_UP'];
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /alert_logs/{documentId} {
      allow create: if hasOnlyAllowedKeys(['normalizedMedicineName', 'userId', 'createdAt']);
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /delivery_simulation_logs/{documentId} {
      allow create: if hasOnlyAllowedKeys(['userId', 'createdAt']);
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
