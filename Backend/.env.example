# =============================================================================
# ConectaPharma — backend local opcional
# =============================================================================
# A versão pública do projeto não depende de backend Python. Este arquivo permanece
# apenas para quem quiser executar scripts locais, simulações ou testes do FastAPI.

# Conta administrativa fixa do projeto.
CONNECTAPHARMA_PLATFORM_ADMIN_EMAIL=claudiofranciscojunior2006@gmail.com
CONNECTAPHARMA_ALLOW_LEGACY_JWT=false
CONNECTAPHARMA_SECRET_KEY=
CONNECTAPHARMA_TIMEZONE=America/Sao_Paulo
CONNECTAPHARMA_OVERPASS_ENABLED=true
CONNECTAPHARMA_OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
CONNECTAPHARMA_OVERPASS_TIMEOUT_SECONDS=12
CONNECTAPHARMA_RNDS_ENABLED=false
CONNECTAPHARMA_RNDS_ENVIRONMENT=homologacao

# =============================================================================
# Integration Gateway — APIs oficiais, webhooks e arquivos autorizados
# =============================================================================
# Segredo HMAC padrão para desenvolvimento local. Em produção, use um segredo por
# parceiro no Secret Manager, variável protegida do ambiente ou cofre equivalente.
CONNECTAPHARMA_WEBHOOK_SECRET=
CONNECTAPHARMA_WEBHOOK_MAX_SKEW_SECONDS=300

# Exemplos de segredos por parceiro. Não preencher com valores reais no repositório.
CONNECTAPHARMA_WEBHOOK_SECRET_RD_MARKETPLACE_DEMO=
CONNECTAPHARMA_WEBHOOK_SECRET_ARAUJO_PRIVATE=
CONNECTAPHARMA_WEBHOOK_SECRET_DPSP_PRIVATE=
CONNECTAPHARMA_WEBHOOK_SECRET_CSV_MANUAL=
