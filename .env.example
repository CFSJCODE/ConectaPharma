# =============================================================================
# ConectaPharma — variáveis de ambiente de desenvolvimento
# =============================================================================
# Este arquivo é um modelo. Para execução local, copie para `.env` e ajuste apenas
# caminhos locais/segredos privados. Não versionar service accounts do Firebase.

# -----------------------------------------------------------------------------
# Firebase Web SDK — frontend
# -----------------------------------------------------------------------------
# Configuração pública do app Web registrada no Firebase Console.
# No frontend estático atual, estes mesmos valores também estão centralizados em:
# Frontend/assets/firebaseClient.js
VITE_FIREBASE_API_KEY=AIzaSyCN4we2-58ZJXy0TCxVpcdTzo5dvlDrCXw
VITE_FIREBASE_AUTH_DOMAIN=conectapharma-33fd7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=conectapharma-33fd7
VITE_FIREBASE_STORAGE_BUCKET=conectapharma-33fd7.firebasestorage.app
VITE_FIREBASE_APP_ID=1:137881875886:web:499dc824977b90cebe443f
VITE_FIREBASE_MESSAGING_SENDER_ID=137881875886
VITE_FIREBASE_MEASUREMENT_ID=G-QEJ27VVTM7

# -----------------------------------------------------------------------------
# Firebase Admin SDK — backend FastAPI
# -----------------------------------------------------------------------------
# Caminho local para o JSON de service account baixado no Firebase Console.
# Nunca versionar esse arquivo JSON no GitHub.
CONNECTAPHARMA_FIREBASE_PROJECT_ID=conectapharma-33fd7
CONNECTAPHARMA_FIREBASE_CREDENTIALS_PATH=
CONNECTAPHARMA_FIREBASE_VERIFY_REVOKED=false

# Alternativa compatível com Google Application Default Credentials.
# GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# Compatibilidade temporária com JWT legado do backend antigo
# -----------------------------------------------------------------------------
# Deixe false no MVP público quando a autenticação principal for Firebase.
CONNECTAPHARMA_ALLOW_LEGACY_JWT=false

# -----------------------------------------------------------------------------
# Configurações legadas/opcionais do backend
# -----------------------------------------------------------------------------
CONNECTAPHARMA_SECRET_KEY=
CONNECTAPHARMA_RNDS_ENABLED=false
CONNECTAPHARMA_RNDS_ENVIRONMENT=homologacao
CONNECTAPHARMA_RNDS_AUTH_URL=https://ehr-auth-hmg.saude.gov.br/api
CONNECTAPHARMA_RNDS_SERVICES_URL=https://ehr-services.hmg.saude.gov.br/api
CONNECTAPHARMA_RNDS_DOCUMENT_ENDPOINT=/fhir/r4/Bundle
CONNECTAPHARMA_RNDS_CLIENT_CERT_PATH=
CONNECTAPHARMA_RNDS_CLIENT_KEY_PATH=
CONNECTAPHARMA_RNDS_VERIFY_TLS=true
CONNECTAPHARMA_RNDS_TIMEOUT_SECONDS=15
CONNECTAPHARMA_ESTABELECIMENTO_CNES=

# -----------------------------------------------------------------------------
# OpenStreetMap / Overpass — farmácias próximas
# -----------------------------------------------------------------------------
# Serviço gratuito usado pelo backend para consultar farmácias públicas no OSM.
# Em hospedagem estática sem backend público configurado, o frontend também possui
# fallback direto ao OpenStreetMap para não quebrar a experiência do usuário.
CONNECTAPHARMA_TIMEZONE=America/Sao_Paulo
CONNECTAPHARMA_OVERPASS_ENABLED=true
CONNECTAPHARMA_OVERPASS_URL=https://overpass-api.de/api/interpreter
CONNECTAPHARMA_OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
CONNECTAPHARMA_OVERPASS_TIMEOUT_SECONDS=12
CONNECTAPHARMA_OVERPASS_CACHE_TTL_SECONDS=900
CONNECTAPHARMA_OVERPASS_RESPONSE_CACHE_TTL_SECONDS=60
CONNECTAPHARMA_OVERPASS_MAX_CONNECTIONS=8
CONNECTAPHARMA_OVERPASS_MAX_KEEPALIVE_CONNECTIONS=4
CONNECTAPHARMA_OVERPASS_USER_AGENT="ConectaPharma-MVP/1.0 (academic prototype; contact: claudiofranciscojunior2006@gmail.com)"


# CORS adicional para backend público opcional. Separe múltiplas origens por vírgula.
CONNECTAPHARMA_CORS_ORIGINS=https://conectapharma-33fd7.web.app,https://conectapharma-33fd7.firebaseapp.com,https://cfsjcode.github.io

# -----------------------------------------------------------------------------
# Google Maps Platform / Places API (opcional, mais confiável para farmácias)
# -----------------------------------------------------------------------------
# Requer billing habilitado no Google Cloud e Places API (New) ativa.
# Mantenha a chave apenas no backend. Nunca coloque essa chave no frontend.
CONNECTAPHARMA_GOOGLE_PLACES_ENABLED=false
CONNECTAPHARMA_GOOGLE_MAPS_API_KEY=
CONNECTAPHARMA_GOOGLE_PLACES_NEARBY_URL=https://places.googleapis.com/v1/places:searchNearby
CONNECTAPHARMA_GOOGLE_PLACES_TEXT_URL=https://places.googleapis.com/v1/places:searchText
CONNECTAPHARMA_GOOGLE_PLACES_TIMEOUT_SECONDS=10
CONNECTAPHARMA_GOOGLE_PLACES_CACHE_TTL_SECONDS=900
CONNECTAPHARMA_GOOGLE_PLACES_RESPONSE_CACHE_TTL_SECONDS=60
CONNECTAPHARMA_GOOGLE_PLACES_MAX_RESULT_COUNT=20
CONNECTAPHARMA_GOOGLE_PLACES_LANGUAGE_CODE=pt-BR
CONNECTAPHARMA_GOOGLE_PLACES_REGION_CODE=BR
