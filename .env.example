# Backend
CONNECTAPHARMA_SECRET_KEY=troque-por-uma-chave-com-32-ou-mais-caracteres

# Integracao DATASUS/RNDS
# Deixe false para desenvolvimento, demos e publicacao no GitHub.
CONNECTAPHARMA_RNDS_ENABLED=false
CONNECTAPHARMA_RNDS_ENVIRONMENT=homologacao

# URLs oficiais sao liberadas/conferidas no Portal de Servicos DATASUS apos credenciamento.
# Exemplos de homologacao citados em materiais publicos podem mudar; valide no portfolio aprovado.
CONNECTAPHARMA_RNDS_AUTH_URL=https://ehr-auth-hmg.saude.gov.br/api
CONNECTAPHARMA_RNDS_SERVICES_URL=https://ehr-services.hmg.saude.gov.br/api
CONNECTAPHARMA_RNDS_DOCUMENT_ENDPOINT=/fhir/r4/Bundle

# Use caminhos locais fora do repositório ou dentro de uma pasta ignorada, como certs/.
# O cliente aceita certificado PEM unico ou par certificado/chave PEM.
CONNECTAPHARMA_RNDS_CLIENT_CERT_PATH=
CONNECTAPHARMA_RNDS_CLIENT_KEY_PATH=
CONNECTAPHARMA_RNDS_VERIFY_TLS=true
CONNECTAPHARMA_RNDS_TIMEOUT_SECONDS=15

# Dados institucionais usados no payload quando nao vierem na requisicao.
CONNECTAPHARMA_ESTABELECIMENTO_CNES=
