# =============================================================================
# ConectaPharma — variáveis de ambiente do projeto estático gratuito
# =============================================================================
# O frontend publicado no Firebase Hosting usa Firebase Authentication,
# Cloud Firestore e OpenStreetMap/Overpass. Não há backend Python obrigatório
# em produção e não há chave Google Maps/Places.

# Firebase Web SDK — configuração pública do app Web.
# Estes valores também estão centralizados em Frontend/assets/firebaseClient.js.
VITE_FIREBASE_API_KEY=AIzaSyCN4we2-58ZJXy0TCxVpcdTzo5dvlDrCXw
VITE_FIREBASE_AUTH_DOMAIN=conectapharma-33fd7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=conectapharma-33fd7
VITE_FIREBASE_STORAGE_BUCKET=conectapharma-33fd7.firebasestorage.app
VITE_FIREBASE_APP_ID=1:137881875886:web:499dc824977b90cebe443f
VITE_FIREBASE_MESSAGING_SENDER_ID=137881875886
VITE_FIREBASE_MEASUREMENT_ID=G-QEJ27VVTM7

# Controle administrativo do projeto.
# A regra de segurança também reconhece este e-mail como administrador bootstrap.
CONNECTAPHARMA_ADMIN_EMAILS=claudiofranciscojunior2006@gmail.com

# OpenStreetMap / Overpass — usado diretamente pelo frontend para consultas
# públicas de farmácias, UBSs, postos de saúde e UPAs próximos.
CONNECTAPHARMA_TIMEZONE=America/Sao_Paulo
CONNECTAPHARMA_OVERPASS_ENDPOINTS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
